{
  "api_key": "your-api-key-here",
  "provider": "longcat",
  "model": "LongCat-2.0",
  "base_url": "https://api.longcat.chat/anthropic",
  "temperature": 0.8,
  "max_tokens": 4096,
  "concurrency": 3,
  "max_revision_rounds": 3,
  "quality_threshold": 7.0,
  "default_chapter_count": 10,
  "default_chapter_length": 3000,
  "web_monitor_port": 5000,
  "enable_outline_agent": true,
  "outline_max_tokens": 8192,
  "outline_temperature": 0.7
}
